<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sound &amp; Vibration"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#2196F3"
        android:layout_marginBottom="20dp"/>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switch_vibrate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="15dp"
        android:text="Vibrate on keypress"
        android:textSize="18sp"/>

    <LinearLayout
        android:id="@+id/layout_vibrate_strength"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp"
        android:clickable="true"
        android:focusable="true">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vibration Strength" android:textSize="18sp" android:textColor="#000000"/>
        <TextView android:id="@+id/tv_vibrate_strength_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="System Default" android:textSize="14sp" android:textColor="#888888" android:layout_marginTop="4dp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switch_sound"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="15dp"
        android:text="Sound on keypress"
        android:textSize="18sp"/>

    <LinearLayout
        android:id="@+id/layout_sound_volume"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp"
        android:clickable="true"
        android:focusable="true">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sound Volume" android:textSize="18sp" android:textColor="#000000"/>
        <TextView android:id="@+id/tv_sound_volume_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Normal" android:textSize="14sp" android:textColor="#888888" android:layout_marginTop="4dp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btn_import_sound_zip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Import Custom Sounds (.zip)"
        android:padding="12dp"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btn_reset_sound"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Use System Default Sound"
        android:textColor="#F44336"
        android:backgroundTint="#FFEBEE"
        style="@style/Widget.AppCompat.Button.Borderless"
        android:padding="12dp"/>

</LinearLayout>

